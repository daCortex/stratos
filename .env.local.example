# Stratos — copy to .env.local and fill in to go live.
# Everything runs in a seeded in-memory demo without any of these set.

# Neon Postgres (multi-tenant store). When unset, Stratos uses an in-memory demo store.
DATABASE_URL=

# Secret used to sign session cookies. Set a long random string in production.
SESSION_SECRET=

# Optional: Infinite Flight API key for live flights + logbook validation (shared across VAs).
IF_API_KEY=

# ─────────────────────────────────────────────────────────────
# Suite control plane (managed from Aileron — see aileron/SUITE.md)
# ─────────────────────────────────────────────────────────────
# Stratos polls Aileron's /api/control to honor status / maintenance / flags.

# Aileron's URL. Only set if it's NOT the default https://aileronifc.vercel.app.
AILERON_CONTROL_URL=

# Must MATCH the CONTROL_SECRET set on Aileron. If Aileron has one and this is
# blank (or different), polls get 403 and Stratos fails-open to "operational".
CONTROL_SECRET=
